{
  "name": "@rising-company/wave-maker-react",
  "version": "0.1.1",
  "description": "React component for wave-maker WebGL gradients",
  "author": "Ben Cao <ben@rising.company>",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": { "types": "./dist/index.d.ts", "default": "./dist/index.js" },
      "require": { "types": "./dist/index.d.cts", "default": "./dist/index.cjs" }
    }
  },
  "files": ["dist"],
  "scripts": { "build": "tsup" },
  "keywords": [
    "react",
    "react-component",
    "react-gradient",
    "webgl",
    "gradient",
    "animated-gradient",
    "mesh-gradient",
    "wave",
    "waves",
    "animation",
    "animated-background",
    "background",
    "hero",
    "hero-section",
    "canvas",
    "shader",
    "glsl",
    "visual-effects",
    "ui"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rising-company/wave-maker.git",
    "directory": "packages/react"
  },
  "homepage": "https://github.com/rising-company/wave-maker#readme",
  "bugs": "https://github.com/rising-company/wave-maker/issues",
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "@rising-company/wave-maker-core": "workspace:*",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@rising-company/wave-maker-core": "workspace:*",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.0.0"
  }
}
