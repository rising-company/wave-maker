{
  "name": "@rising-company/wave-maker",
  "version": "0.1.0",
  "description": "Beautiful animated WebGL wave gradient effects",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "webgl",
    "gradient",
    "wave",
    "animation",
    "shader"
  ],
  "license": "MIT",
  "devDependencies": {
    "jsdom": "^29.0.2",
    "tsup": "^8.0.0",
    "vitest": "^3.0.0"
  }
}
